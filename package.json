{
  "name": "rostok",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "get-android-version": "node scripts/get-android-version.js",
    "sync-android-version": "node scripts/sync-android-version.js",
    "update-android": "npm run build && npm run sync-android-version && npx cap sync android",
    "build-debug-apk": "cd android && gradlew assembleDebug",
    "upload-release": "node scripts/upload-release.js",
    "release": "npm run update-android && npm run build-debug-apk && node scripts/upload-release.js",
    "test": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.47.10",
    "@types/canvas-confetti": "^1.9.0",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "lucide-vue-next": "^0.563.0",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^9.14.5",
    "vue-qrcode-reader": "^5.5.3",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "sass": "^1.83.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
